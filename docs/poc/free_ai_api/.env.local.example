# Copy this file to `.env.local` and set only the providers you want to test.
# If `*_MODEL` is empty, `ai_api_poc.py` falls back to the default model shown in the comment.
# If `*_MODELS` is set, it takes precedence over `*_MODEL`.

GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEYS=
# Default fallback: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODELS=

GROQ_API_KEY=
GROQ_API_KEYS=
# Default fallback: llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODELS=

OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
# Default fallback: openrouter/auto
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_MODELS=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=

MISTRAL_API_KEY=
MISTRAL_API_KEYS=
# Default fallback: mistral-small-latest
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MODELS=

COHERE_API_KEY=
COHERE_API_KEYS=
# Default fallback: command-a-03-2025
COHERE_MODEL=command-a-03-2025
COHERE_MODELS=

HF_TOKEN=
HF_TOKENS=
# Default fallback: openai/gpt-oss-120b
HF_MODEL=openai/gpt-oss-120b
HF_MODELS=

GITHUB_MODELS_TOKEN=
GITHUB_MODELS_TOKENS=
# Default fallback: openai/gpt-4o-mini
GITHUB_MODELS_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_MODELS=

CEREBRAS_API_KEY=
CEREBRAS_API_KEYS=
# Default fallback: llama3.1-8b
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_MODELS=

SAMBANOVA_API_KEY=
SAMBANOVA_API_KEYS=
# Default fallback: Meta-Llama-3.3-70B-Instruct
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_MODELS=

FIREWORKS_API_KEY=
FIREWORKS_API_KEYS=
# Default fallback: accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_MODELS=

AI_API_POC_PROMPT=Return exactly: HelloWorld
AI_API_POC_TIMEOUT_SECONDS=30
