# Production Smoke Test Secrets
# Copy to .env.prod.smoke and fill in values
# See: docs/operations/runbooks/seed-smoke-user.md
# See: docs/operations/runbooks/create-admin-account.md

# Smoke user edge-token (seed-smoke-user.md Step 1)
PROD_SMOKE_EDGE_TOKEN=

# Smoke user ID (seed-smoke-user.md Step 2)
# SQL: SELECT id FROM users WHERE author_id_seed = 'SMOKE_TEST';
PROD_SMOKE_USER_ID=

# Admin credentials (create-admin-account.md)
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=

# Production base URL
PROD_BASE_URL=https://battle-board.shika.workers.dev
