{
  "name": "battle_board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "cucumber-js",
    "test:bdd:dry": "cucumber-js --dry-run",
    "test:bdd:integration": "cucumber-js --profile integration",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --ui",
    "test:api": "playwright test --project=api",
    "test:cf-smoke": "playwright test --project=cf-smoke",
    "build:cf": "node scripts/build-cf.mjs",
    "preview:cf": "npx wrangler dev",
    "deploy:cf": "node scripts/build-cf.mjs && npx wrangler deploy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "iconv-lite": "^0.7.2",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wrangler": "^4.73.0"
  }
}
