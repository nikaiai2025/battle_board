{
  "permissions": {
    "allow": [
      "Bash(xargs ls -la)",
      "Bash(npm install:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(npx vitest:*)",
      "Bash(npx cucumber-js:*)",
      "Bash(ls:*)",
      "Bash(npx tsc:*)",
      "Bash(for f in features/*.feature)",
      "Bash(do echo \"=== $f ===\")",
      "Read(//c/Users/user/Documents/PGM連携/battle_board/**)",
      "Bash(done)",
      "Bash(wc:*)",
      "Bash(node:*)",
      "Bash(TS_NODE_PROJECT=tsconfig.cucumber.json npx cucumber-js:*)",
      "Bash(grep:*)",
      "Bash(npx shadcn@latest:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-rm.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-manual-deploy.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path') && [[ $FILE == *.ts || $FILE == *.tsx || $FILE == *.js || $FILE == *.jsx ]] && biome format --write $FILE && biome check --fix $FILE || true"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-cucumber-slash.sh"
          }
        ]
      }
    ]
  }
}
